<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="AzimuthV3">

<xacro:arg name="prefix" default=""/>
<xacro:property name="pkg" value="swarm_robot_description"/>

<!-- Azimuth_bot re-design version due to plugins and packages issues -->
<link name="base_link">
  <inertial>
    <origin xyz="0 0 0.06" rpy="0 0 0"/>
    <mass value="1.6608"/>
    <inertia ixx="0.0092313" ixy="0" ixz="0" iyy="0.0092314" iyz="0" izz="0.015172"/>
  </inertial>
  <visual>
    <origin xyz="0 0 0.06" rpy="0 0 0"/>
    <geometry>
      <sphere radius="0.12"/>
    </geometry>
    <material name="base_material">
      <color rgba="0.65 0.24 0.24 1"/>
    </material>
  </visual>
  <collision>
    <origin xyz="0 0 0.06" rpy="0 0 0"/>
    <geometry>
      <sphere radius="0.12"/>
    </geometry>
  </collision>
</link>

<link name="Pod_link">
  <inertial>
    <origin xyz="-0.020969 -0.00046657 -0.070974" rpy="0 0 0"/>
    <mass value="0.14581"/>
    <inertia ixx="4.8483E-05" ixy="-6.6571E-07" ixz="-5.2275E-06" iyy="7.8386E-05" iyz="-1.1631E-07" izz="6.0523E-05"/>
  </inertial>
  <visual name="pod_vertical">
    <origin xyz="0 0 -0.04" rpy="0 0 0"/>
    <geometry>
      <cylinder radius="0.025" length="0.08"/>
    </geometry>
    <material name="pod_material">
      <color rgba="0.79 0.82 0.93 1"/>
    </material>
  </visual>
  <visual name="pod_horizontal">
    <origin xyz="-0.04 0 -0.08" rpy="0 1.5708 0"/>
    <geometry>
      <cylinder radius="0.02" length="0.08"/>
    </geometry>
    <material name="pod_material">
      <color rgba="0.79 0.82 0.93 1"/>
    </material>
  </visual>
  <collision>
    <origin xyz="0 0 -0.04" rpy="0 0 0"/>
    <geometry>
      <cylinder radius="0.03" length="0.12"/>
    </geometry>
  </collision>
</link>

<joint name="Pod_Base_joint" type="continuous">
  <origin xyz="0 0 -0.021064" rpy="0 0 0"/>
  <parent link="base_link"/>
  <child link="Pod_link"/>
  <axis xyz="0 0 1"/>
  <dynamics damping="0.2" friction="0.1"/>
</joint>

<link name="Thruster_link">
  <inertial>
    <origin xyz="0 0 0.007" rpy="0 0 0"/>
    <mass value="0.00098034"/>
    <inertia ixx="4.6405E-08" ixy="0" ixz="0" iyy="4.6394E-08" iyz="0" izz="6.7921E-08"/>
  </inertial>
  <visual>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <geometry>
      <cylinder radius="0.035" length="0.015"/>
    </geometry>
    <material name="thruster_material">
      <color rgba="0.2 0.2 0.2 1"/>
    </material>
  </visual>
  <collision>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <geometry>
      <cylinder radius="0.035" length="0.015"/>
    </geometry>
  </collision>
</link>

<joint name="Thruster_Pod_joint" type="continuous">
  <origin xyz="-0.083823 -0.0018651 -0.08" rpy="1.5698 0 -1.5708"/>
  <parent link="Pod_link"/>
  <child link="Thruster_link"/>
  <axis xyz="0 0 1"/>
  <limit effort="100" velocity="100"/>
  <dynamics damping="0.1" friction="0.1"/>
</joint>

<link name="Sensor1_link">
  <inertial>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <mass value="0.0073631"/>
    <inertia ixx="4.2568E-07" ixy="0" ixz="0" iyy="5.7524E-07" iyz="0" izz="4.2568E-07"/>
  </inertial>
  <visual>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <geometry>
      <cylinder radius="0.015" length="0.03"/>
    </geometry>
    <material name="sensor_material">
      <color rgba="0.1 0.8 0.1 1"/>
    </material>
  </visual>
  <collision>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <geometry>
      <cylinder radius="0.015" length="0.03"/>
    </geometry>
  </collision>
</link>

<joint name="Sensor1_Base_joint" type="fixed">
  <origin xyz="0 0.12 0.035776" rpy="0 0 0"/>
  <parent link="base_link"/>
  <child link="Sensor1_link"/>
</joint>

<link name="Sensor2_link">
  <inertial>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <mass value="0.0073631"/>
    <inertia ixx="4.2568E-07" ixy="0" ixz="0" iyy="5.7524E-07" iyz="0" izz="4.2568E-07"/>
  </inertial>
  <visual>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <geometry>
      <cylinder radius="0.015" length="0.03"/>
    </geometry>
    <material name="sensor_material">
      <color rgba="0.1 0.8 0.1 1"/>
    </material>
  </visual>
  <collision>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <geometry>
      <cylinder radius="0.015" length="0.03"/>
    </geometry>
  </collision>
</link>

<joint name="Sensor2_Base_joint" type="fixed">
  <origin xyz="0 -0.12 0.035776" rpy="0 0 0"/>
  <parent link="base_link"/>
  <child link="Sensor2_link"/>
</joint>

<link name="Sensor3_link">
  <inertial>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <mass value="0.0073631"/>
    <inertia ixx="5.7524E-07" ixy="0" ixz="0" iyy="4.2568E-07" iyz="0" izz="4.2568E-07"/>
  </inertial>
  <visual>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <geometry>
      <cylinder radius="0.015" length="0.03"/>
    </geometry>
    <material name="sensor_material">
      <color rgba="0.1 0.8 0.1 1"/>
    </material>
  </visual>
  <collision>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <geometry>
      <cylinder radius="0.015" length="0.03"/>
    </geometry>
  </collision>
</link>

<joint name="Sensor3_Base_joint" type="fixed">
  <origin xyz="0.12 0 0.035776" rpy="0 0 0"/>
  <parent link="base_link"/>
  <child link="Sensor3_link"/>
</joint>

<link name="Sensor4_link">
  <inertial>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <mass value="0.0073631"/>
    <inertia ixx="5.7524E-07" ixy="0" ixz="0" iyy="4.2568E-07" iyz="0" izz="4.2568E-07"/>
  </inertial>
  <visual>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <geometry>
      <cylinder radius="0.015" length="0.03"/>
    </geometry>
    <material name="sensor_material">
      <color rgba="1 0.8 0.1 1"/>
    </material>
  </visual>
  <collision>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <geometry>
      <cylinder radius="0.015" length="0.03"/>
    </geometry>
  </collision>
</link>

<joint name="Sensor4_Base_joint" type="fixed">
  <origin xyz="-0.12 0 0.035776" rpy="0 0 0"/>
  <parent link="base_link"/>
  <child link="Sensor4_link"/>
</joint>

<!-- LASER SENSOR -->
<link name="laser_link">
  <inertial>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <mass value="0.001"/>
    <inertia ixx="1e-6" ixy="0" ixz="0" iyy="1e-6" iyz="0" izz="1e-6"/>
  </inertial>
  <visual>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <geometry>
      <cylinder radius="0.02" length="0.02"/>
    </geometry>
    <material name="laser_material">
      <color rgba="0 0 0 1"/>
    </material>
  </visual>
  <collision>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <geometry>
      <cylinder radius="0.02" length="0.02"/>
    </geometry>
  </collision>
</link>

<joint name="laser_joint" type="fixed">
  <origin xyz="0 0 0.15" rpy="0 0 0"/>
  <parent link="base_link"/>
  <child link="laser_link"/>
</joint>

<!-- GAZEBO PLUGIN FOR LASER (It has some issues sometimes) -->
<gazebo reference="laser_link">
  <material>Gazebo/Black</material>
  <sensor name="laser_sensor" type="ray">
    <pose>0 0 0 0 0 0</pose>
    <visualize>true</visualize>
    <update_rate>10</update_rate>
    <ray>
      <scan>
        <horizontal>
          <samples>180</samples>
          <resolution>1</resolution>
          <min_angle>-1.5708</min_angle>
          <max_angle>1.5708</max_angle>
        </horizontal>
      </scan>
      <range>
        <min>0.1</min>
        <max>5.0</max>
        <resolution>0.01</resolution>
      </range>
      <noise>
        <type>gaussian</type>
        <mean>0.0</mean>
        <stddev>0.01</stddev>
      </noise>
    </ray>
    <plugin name="laser_controller" filename="libgazebo_ros_ray_sensor.so">
      <ros>
        <namespace>/swarm</namespace>
        <remapping>~/out:=laser_scan</remapping>
      </ros>
      <output_type>sensor_msgs/LaserScan</output_type>
      <frame_name>laser_link</frame_name>
    </plugin>
  </sensor>
</gazebo>

<!-- Gazebo Colors -->
<gazebo reference="base_link">
  <material>Gazebo/Red</material>
</gazebo>

<gazebo reference="Pod_link">
  <material>Gazebo/Blue</material>
</gazebo>

<gazebo reference="Thruster_link">
  <material>Gazebo/Grey</material>
</gazebo>

<gazebo reference="Sensor1_link">
  <material>Gazebo/Green</material>
</gazebo>

<gazebo reference="Sensor2_link">
  <material>Gazebo/Green</material>
</gazebo>

<gazebo reference="Sensor3_link">
  <material>Gazebo/Green</material>
</gazebo>

<gazebo reference="Sensor4_link">
  <material>Gazebo/Yellow</material>
</gazebo>

</robot>